# ============================================================
# PolicyLens Node.js Backend — Environment Variables Template
# Copy to backend/.env and fill in real values.
# NEVER commit backend/.env — it is gitignored.
# ============================================================

# ── Server Port ────────────────────────────────────────────────
PORT=4000

# ── Supabase — same project as Python backend (REQUIRED) ───────
# Dashboard → Project Settings → API
# !! Use the service_role secret key — NOT the anon/public key !!
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Secret (REQUIRED) ──────────────────────────────────
# Any long random string — used to sign auth tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-long-random-secret-here

# ── Python Backend URL (REQUIRED) ───────────────────────────
# URL where the Python FastAPI server is running
# Local dev: http://localhost:8000
# Production: https://your-python-service.railway.app or similar
PYTHON_API_URL=http://localhost:8000

# ── CORS Origins (RECOMMENDED IN PRODUCTION) ───────────────
# Comma-separated list. Use * only for temporary/dev usage.
# Example: https://policylens-ai.vercel.app,http://localhost:5173
CORS_ORIGINS=*
